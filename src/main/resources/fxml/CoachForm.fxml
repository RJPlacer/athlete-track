<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sdms.controller.CoachFormController"
      prefWidth="780" prefHeight="620" styleClass="form-root">

    <HBox styleClass="form-header" alignment="CENTER_LEFT" spacing="12">
        <padding><Insets top="14" bottom="14" left="20" right="20"/></padding>
        <Label text="Coach Record" styleClass="form-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblGeneratedId" styleClass="id-badge"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="form-tabs">

        <!-- A. Personal Data -->
        <Tab text="A. Personal Data">
            <ScrollPane fitToWidth="true">
                <GridPane hgap="12" vgap="10" style="-fx-padding: 16 20 16 20;">
                    <Label text="Last Name *"          GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtLastName"      GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="2" maxWidth="Infinity"/>
                    <Label text="First Name *"          GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtFirstName"     GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="M.I."                  GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtMiddleInitial" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="60" maxWidth="60"/>
                    <Label text="Sex *"                 GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbSex"            GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label text="Mobile Phone"          GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtMobile"        GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label text="Date of Birth"         GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="dpDateOfBirth"   GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <Label text="Age"                   GridPane.rowIndex="4" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtAge"           GridPane.rowIndex="4" GridPane.columnIndex="3" prefWidth="60" maxWidth="60"/>
                    <Label text="Place of Birth"        GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtPlaceOfBirth"  GridPane.rowIndex="5" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Current Position"      GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtPosition"      GridPane.rowIndex="6" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Years in Service"      GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtYearsService"  GridPane.rowIndex="7" GridPane.columnIndex="1" prefWidth="80"/>
                    <Label text="School"                GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtSchool"        GridPane.rowIndex="8" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Employee Number"       GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEmployeeNo"    GridPane.rowIndex="9" GridPane.columnIndex="1"/>
                    <Label text="Address of School"     GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                    <TextArea  fx:id="txaSchoolAddress" GridPane.rowIndex="10" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity" prefRowCount="2"/>
                    <Label text="Present Address"       GridPane.rowIndex="11" GridPane.columnIndex="0"/>
                    <TextArea  fx:id="txaPresentAddress" GridPane.rowIndex="11" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity" prefRowCount="2"/>
                    <Label text="Emergency Contact"     GridPane.rowIndex="12" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEmergencyName" GridPane.rowIndex="12" GridPane.columnIndex="1" promptText="Name"/>
                    <TextField fx:id="txtEmergencyNo"   GridPane.rowIndex="12" GridPane.columnIndex="3" promptText="Contact No."/>
                    <Label text="Photo (1x1)"           GridPane.rowIndex="13" GridPane.columnIndex="0"/>
                    <HBox spacing="8" alignment="CENTER_LEFT" GridPane.rowIndex="13" GridPane.columnIndex="1" GridPane.columnSpan="3">
                        <ImageView fx:id="imgPhoto" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                        <VBox spacing="4">
                            <Button text="Choose Photo…" onAction="#onChoosePhoto" styleClass="btn-secondary"/>
                            <Label fx:id="lblPhotoPath" text="No photo selected" styleClass="hint-label"/>
                        </VBox>
                    </HBox>
                    <columnConstraints>
                        <ColumnConstraints minWidth="140" maxWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="50" maxWidth="80"/>
                        <ColumnConstraints minWidth="100" maxWidth="140"/>
                    </columnConstraints>
                </GridPane>
            </ScrollPane>
        </Tab>

        <!-- B. Educational Qualifications -->
        <Tab text="B. Education">
            <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                <Label text="Educational Qualifications" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <GridPane hgap="10" vgap="8">
                    <Label text="Level"                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbEduLevel"         GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Course"                  GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtEduCourse"       GridPane.rowIndex="0" GridPane.columnIndex="3" maxWidth="Infinity"/>
                    <Label text="School"                  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEduSchool"       GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Year Graduated"          GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEduYear"         GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label text="Credits Earned"          GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtEduCredits"      GridPane.rowIndex="2" GridPane.columnIndex="3" maxWidth="Infinity"/>
                    <Label text="Awards Received"         GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEduAwards"       GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <columnConstraints>
                        <ColumnConstraints minWidth="110"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="110"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>
                <HBox spacing="8">
                    <Button text="+ Add Row" onAction="#onAddEducation" styleClass="btn-primary"/>
                    <Button text="Remove Selected" onAction="#onRemoveEducation" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="tblEducation" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colEduLevel"  text="Level"          prefWidth="100"/>
                        <TableColumn fx:id="colEduCourse" text="Course"         prefWidth="160"/>
                        <TableColumn fx:id="colEduSchool" text="School"         prefWidth="160"/>
                        <TableColumn fx:id="colEduYear"   text="Year Graduated" prefWidth="110"/>
                        <TableColumn fx:id="colEduAwards" text="Awards"         prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- C. Sports Training -->
        <Tab text="C. Sports Training">
            <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                <Label text="Sports Training Attended (Last 3 Years)" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <GridPane hgap="10" vgap="8">
                    <Label text="Title"              GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrainTitle" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Date"               GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrainDate"  GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="No. of Hours"       GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtTrainHours" GridPane.rowIndex="1" GridPane.columnIndex="3" maxWidth="Infinity"/>
                    <Label text="Conducted By"       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrainBy"    GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <columnConstraints>
                        <ColumnConstraints minWidth="110"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="100"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>
                <HBox spacing="8">
                    <Button text="+ Add Row" onAction="#onAddTraining" styleClass="btn-primary"/>
                    <Button text="Remove Selected" onAction="#onRemoveTraining" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="tblTraining" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colTrainTitle" text="Title"        prefWidth="200"/>
                        <TableColumn fx:id="colTrainDate"  text="Date"         prefWidth="110"/>
                        <TableColumn fx:id="colTrainHours" text="Hours"        prefWidth="70"/>
                        <TableColumn fx:id="colTrainBy"    text="Conducted By" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- D. Track Record -->
        <Tab text="D. Track Record">
            <VBox spacing="8" style="-fx-padding: 12 16 12 16;">
                <Label text="Sports Track Record / Experience" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                <GridPane hgap="10" vgap="8">
                    <Label text="Meet Attended"        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrackMeet"    GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <Label text="Inclusive Dates"      GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrackDates"   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Event"                GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="txtTrackEvent"   GridPane.rowIndex="1" GridPane.columnIndex="3" maxWidth="Infinity"/>
                    <Label text="Awards Received"      GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtTrackAwards"  GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
                    <columnConstraints>
                        <ColumnConstraints minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                        <ColumnConstraints minWidth="80"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                </GridPane>
                <HBox spacing="8">
                    <Button text="+ Add Row" onAction="#onAddTrack" styleClass="btn-primary"/>
                    <Button text="Remove Selected" onAction="#onRemoveTrack" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="tblTrack" VBox.vgrow="ALWAYS" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="colTrackMeet"   text="Meet Attended"   prefWidth="180"/>
                        <TableColumn fx:id="colTrackDates"  text="Inclusive Dates" prefWidth="130"/>
                        <TableColumn fx:id="colTrackEvent"  text="Event"           prefWidth="130"/>
                        <TableColumn fx:id="colTrackAwards" text="Awards"          prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>

    <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="form-footer">
        <padding><Insets top="12" bottom="12" left="20" right="20"/></padding>
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
        <Button text="Save Coach" onAction="#onSave" styleClass="btn-primary" defaultButton="true"/>
    </HBox>
</VBox>
