<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sdms.controller.ChangePasswordController"
      prefWidth="420" prefHeight="340" styleClass="form-root">

    <HBox styleClass="form-header" alignment="CENTER_LEFT">
        <padding><Insets top="14" bottom="14" left="20" right="20"/></padding>
        <Label text="Change Password" styleClass="form-title"/>
    </HBox>

    <VBox spacing="14" VBox.vgrow="ALWAYS" style="-fx-padding: 24 28 20 28;">
        <Label fx:id="lblUsername" text=""
               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A3A5C;"/>
        <Separator/>
        <GridPane hgap="12" vgap="12">
            <Label text="Current Password"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txtCurrent" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="New Password"       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txtNew"     GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="Confirm New"        GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txtConfirm" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <columnConstraints>
                <ColumnConstraints minWidth="130"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
        </GridPane>
        <Label fx:id="lblError"   text="" wrapText="true"
               style="-fx-text-fill: #DC2626; -fx-font-size: 11px;"/>
        <Label fx:id="lblSuccess" text="" wrapText="true"
               style="-fx-text-fill: #16A34A; -fx-font-size: 11px;"/>
    </VBox>

    <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="form-footer">
        <padding><Insets top="12" bottom="12" left="20" right="20"/></padding>
        <Button text="Cancel"          onAction="#onCancel" styleClass="btn-secondary"/>
        <Button text="Change Password" onAction="#onSave"   styleClass="btn-primary" defaultButton="true"/>
    </HBox>
</VBox>
